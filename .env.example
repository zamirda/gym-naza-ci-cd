# Copia este archivo a ".env" (sin ".example") y rellena los valores reales.
# ".env" nunca se sube a git (ya está en .gitignore y .dockerignore).
# En Render, estas mismas variables se configuran en el Dashboard:
# Service -> Environment -> Add Environment Variable.

# Genera una clave nueva y única (no la compartas ni la subas a git).
SECRET_KEY=pega-aqui-una-clave-larga-y-aleatoria

DEBUG=False

EMAIL_HOST_USER=gymnazareth@gmail.com
# Genera una nueva contraseña de aplicación en https://myaccount.google.com/apppasswords
# (la anterior quedó expuesta en el repositorio público y debe considerarse invalida)
EMAIL_HOST_PASSWORD=

# Superusuario creado automáticamente al iniciar el contenedor (ver entrypoint.sh).
# Si no defines estas variables, se usan los valores por defecto que ya están
# escritos en entrypoint.sh (Samir / samirdavid@gmail.com / Samyr2580).
# Recomendado: definirlas aquí (o en Render) con una contraseña propia, para no
# depender del valor por defecto que queda visible en el código.
DJANGO_SUPERUSER_USERNAME=Samir
DJANGO_SUPERUSER_EMAIL=samirdavid@gmail.com
DJANGO_SUPERUSER_PASSWORD=Samyr2580
